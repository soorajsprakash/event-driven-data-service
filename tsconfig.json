{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "skipLibCheck": true,
        "lib": ["es6", "dom"],
        "moduleResolution": "node",
        "rootDir": "./src",
        "outDir": "./lib",
        "declaration": true,
        "strict": true,
        "sourceMap": false,
        "esModuleInterop": true,
        "inlineSourceMap": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "strictNullChecks": false,
        "noImplicitReturns": true,
        "preserveConstEnums": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "./",
        "paths": {
            "src/*": ["./src/*"],
            "apis/*": ["./src/apis/*"],
            "models/*": ["./src/models/*"],
            "services/*": ["./src/services/*"],
            "routes/*": ["./src/routes/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "build", "webpack"],
    "types": ["typePatches"]
}
